{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://finanzarc.runasp.net/api/:path*"
    },
    {
      "source": "/Uploads/:path*",
      "destination": "http://finanzarc.runasp.net/Uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
